rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "hasan23@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'));
    }

    function isSupportAgent() {
      return isAuthenticated() && 
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'support'));
    }

    function isChatOwner(chatId) {
      return isAuthenticated() && (request.auth.uid == chatId || request.auth.token.email == chatId);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             (!('name' in data) || (data.name is string && data.name.size() < 100)) &&
             (!('balance' in data) || data.balance is number) &&
             (!('demoBalance' in data) || data.demoBalance is number) &&
             (!('role' in data) || data.role in ['user', 'admin', 'support']);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'timestamp']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             data.sender in ['user', 'support', 'admin', 'system'];
    }

    // ===============================================================
    // User Profile Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (!('role' in request.resource.data) || request.resource.data.role == 'user');
      
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                        (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) || 
                      isAdmin() || 
                      (isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'receivedTransferTotal']) &&
                       request.resource.data.balance > resource.data.balance);
      
      match /referrals/{referralId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAdmin(); 
        allow update: if isAdmin();
      }
    }

    // Chat Rules
    match /chats/{chatId} {
      allow read: if isChatOwner(chatId) || isAdmin() || isSupportAgent();
      allow create: if isChatOwner(chatId) || isAdmin() || isSupportAgent();
      allow update: if isChatOwner(chatId) || isAdmin() || isSupportAgent();

      match /messages/{messageId} {
        allow read: if isChatOwner(chatId) || isAdmin() || isSupportAgent();
        allow create: if (isChatOwner(chatId) || isAdmin() || isSupportAgent()) && isValidMessage(request.resource.data);
      }
    }
  }
}
