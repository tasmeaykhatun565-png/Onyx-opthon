rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tasmeaykhatun565@gmail.com' ||
        // Optional: check for admin role in users collection could be added here
        // But for now, hardcoded master admin is safer for initial setup
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Rules ---

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      // Allow searching users by email with a strict limit for transfers
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 1);

      function isValidUser(data) {
        return data.size() >= 4 && 
               data.uid == userId &&
               data.email is string &&
               (data.get('role', 'user') in ['user', 'admin']);
      }

      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if (isOwner(userId) && (
        // Prevent users from changing their own role
        incoming().get('role', 'user') == existing().get('role', 'user') &&
        (
          // Action: Update preferences
          (incoming().diff(existing()).affectedKeys().hasOnly(['preferences'])) ||
          // Action: Update basic profile
          (incoming().diff(existing()).affectedKeys().hasAny(['name', 'country', 'currency', 'currencySymbol', 'currencyName', 'currencyFlag'])) ||
          // Action: Balance & Trading updates
          (incoming().diff(existing()).affectedKeys().hasAny(['balance', 'demoBalance', 'bonusBalance', 'extraAccounts', 'turnover_achieved', 'turnover_required', 'kycStatus', 'lastSeen', 'lastTransferAt', 'sentToUids', 'receivedTransferTotal']))
        )
      )) || isAdmin();
      
      // Trade Rules (Nested)
      match /trades/{tradeId} {
        allow read: if isOwner(userId) || isAdmin();
        
        function isValidTrade(data) {
          return data.userId == request.auth.uid &&
                 data.amount is number &&
                 data.amount > 0 &&
                 data.status in ['ACTIVE', 'WIN', 'LOSS'];
        }

        allow create: if isOwner(userId) && isValidTrade(incoming());
        allow update: if (isOwner(userId) && (
          incoming().diff(existing()).affectedKeys().hasAny(['status', 'closePrice', 'profit', 'endTime'])
        )) || isAdmin();
      }

      // Financial Transactions Rules (Nested)
      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isAdmin();
      }
    }

    // Root Transactions (used in TransferFlow.tsx)
    match /transactions/{txId} {
      // Users can see transactions they are part of
      allow read: if isSignedIn() && (
        resource.data.get('userId', '') == request.auth.uid || 
        resource.data.get('recipientId', '') == request.auth.uid || 
        isAdmin()
      );
      // Users can create internal transfers OR deposits (if handled root-level)
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Referrals (used in ReferralPage.tsx)
    match /referrals/{referralId} {
      // A user can read a referral if they are the referrer
      allow read: if isSignedIn() && (
        resource.data.referrerId == request.auth.uid || 
        isAdmin()
      );
      // Standard users need to list referrals where they are the referrer
      allow list: if isSignedIn() && (
        resource.data.referrerId == request.auth.uid || 
        isAdmin()
      );
      // Standard users can create a referral record when someone joins via their link
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }
    
    // Global stats or settings
    match /stats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
