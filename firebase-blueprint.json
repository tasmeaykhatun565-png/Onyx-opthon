{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "demoBalance": { "type": "number" },
        "referredBy": { "type": "string", "description": "UID of the user who referred this user" },
        "referralCode": { "type": "string", "description": "Unique referral code for this user" },
        "referralCount": { "type": "number" },
        "referralBalance": { "type": "number", "description": "Current referral earnings waiting to hit threshold" },
        "totalReferralEarnings": { "type": "number", "description": "Total lifetime referral earnings" },
        "lastTransferAt": { "type": "number", "description": "Timestamp of the last successful internal transfer" },
        "sentToUids": { "type": "array", "items": { "type": "string" }, "description": "List of user UIDs this user has already sent money to" },
        "receivedTransferTotal": { "type": "number", "description": "Total amount received via internal transfers (locked for re-transfer)" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Record of a referral event or commission",
      "type": "object",
      "properties": {
        "referrerUid": { "type": "string" },
        "referredUid": { "type": "string" },
        "referredEmail": { "type": "string" },
        "amount": { "type": "number", "description": "Commission amount earned" },
        "type": { "type": "string", "enum": ["SIGNUP", "DEPOSIT"] },
        "timestamp": { "type": "number" }
      },
      "required": ["referrerUid", "referredUid", "amount", "type", "timestamp"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Support chat session",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "lastUpdated": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "lastMessage": { "type": "string" }
      },
      "required": ["email", "lastUpdated", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Individual chat message",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "support", "admin", "system"] },
        "timestamp": { "type": "object" }
      },
      "required": ["text", "sender", "timestamp"]
    },
    "PromoCode": {
      "title": "PromoCode",
      "description": "Promotional codes for deposit bonuses",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "description": { "type": "string" },
        "bonusPercentage": { "type": "number" },
        "minDeposit": { "type": "number" },
        "turnoverMultiplier": { "type": "number" },
        "expiresAt": { "type": "number" },
        "title": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["code", "bonusPercentage", "minDeposit", "turnoverMultiplier"]
    },
    "Tournament": {
        "title": "Tournament",
        "description": "Trading tournament details",
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "imageUrl": { "type": "string" },
          "prizeFund": { "type": "number" },
          "startTime": { "type": "number" },
          "endTime": { "type": "number" },
          "status": { "type": "string", "enum": ["upcoming", "active", "finished"], "description": "calculated status or manually set" },
          "isLocked": { "type": "boolean" },
          "description": { "type": "string" },
          "rules": { "type": "string" },
          "participants": { "type": "number" },
          "createdAt": { "type": "number" }
        },
        "required": ["title", "prizeFund", "startTime", "endTime"]
      },
      "Ad": {
        "title": "Ad",
        "description": "Advertisement banner with link",
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "imageUrl": { "type": "string" },
          "linkUrl": { "type": "string" },
          "order": { "type": "number", "description": "Display order" }
        },
        "required": ["title", "imageUrl", "linkUrl"]
      }
    },
    "firestore": {
      "/users/{userId}": {
        "schema": "User",
        "description": "User documents"
      },
      "/users/{userId}/referrals/{referralId}": {
        "schema": "Referral",
        "description": "Referrals made by this user"
      },
      "/chats/{chatId}": {
        "schema": "Chat",
        "description": "Support chat sessions"
      },
      "/chats/{chatId}/messages/{messageId}": {
        "schema": "Message",
        "description": "Chat messages"
      },
      "/tournaments/{tournamentId}": {
        "schema": "Tournament",
        "description": "Trading tournaments"
      },
      "/ads/{adId}": {
        "schema": "Ad",
        "description": "Advertisement banners"
      }
    }
  }
}
