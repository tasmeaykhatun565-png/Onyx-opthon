{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores core user information and trading parameters",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number", "description": "Real account balance" },
        "demoBalance": { "type": "number", "description": "Demo account balance" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "country": { "type": "string" },
        "currency": { "type": "string" },
        "currencySymbol": { "type": "string" },
        "bonusBalance": { "type": "number", "description": "Bonus account balance" },
        "turnover_required": { "type": "number" },
        "turnover_achieved": { "type": "number" },
        "kycStatus": { "type": "string", "enum": ["NONE", "PENDING", "VERIFIED", "REJECTED"] },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number" },
        "preferences": {
          "type": "object",
          "properties": {
            "language": { "type": "string" },
            "chartType": { "type": "string" },
            "timeframe": { "type": "string" },
            "theme": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email", "balance", "demoBalance"]
    },
    "Trade": {
      "title": "Trade Transaction",
      "description": "Records every trade execution and its outcome",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["UP", "DOWN"] },
        "entryPrice": { "type": "number" },
        "closePrice": { "type": "number" },
        "amount": { "type": "number" },
        "payout": { "type": "number" },
        "profit": { "type": "number" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "WIN", "LOSS"] },
        "asset": { "type": "string" },
        "accountType": { "type": "string", "enum": ["DEMO", "REAL"] }
      },
      "required": ["userId", "amount", "startTime", "status", "asset"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Logs for deposits and withdrawals",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "type": { "type": "string", "enum": ["DEPOSIT", "WITHDRAWAL", "INTERNAL_TRANSFER"] },
        "status": { "type": "string", "enum": ["PENDING", "COMPLETED", "CANCELLED", "SUCCESS"] },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "amount", "type", "status"]
    },
    "Referral": {
      "title": "Referral Record",
      "description": "Tracks a single referral and its status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "referrerId": { "type": "string" },
        "referredUserId": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["CLICK", "REGISTERED", "DEPOSITOR", "ACTIVE"] },
        "createdAt": { "type": "number" },
        "earnings": { "type": "number" }
      },
      "required": ["referrerId", "referredUserId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Individual trade records for a user"
    },
    "/users/{userId}/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Deposit and withdrawal history (Nested copies info)"
    },
    "/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Global transactions history (Root level)"
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Tracks all referrals"
    }
  }
}
